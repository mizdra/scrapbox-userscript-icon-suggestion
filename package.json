{
  "name": "scrapbox-userscript-icon-suggestion",
  "version": "5.0.0",
  "description": "Scrapbox's UserScript to suggest and insert icons.",
  "homepage": "https://github.com/mizdra/scrapbox-userscript-icon-suggestion#readme",
  "bugs": {
    "url": "https://github.com/mizdra/scrapbox-userscript-icon-suggestion/issues"
  },
  "license": "MIT",
  "author": "mizdra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizdra/scrapbox-userscript-icon-suggestion.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "NODE_ENV=production rollup -c",
    "watch": "NODE_ENV=production rollup -c -w",
    "dev": "node scripts/dev.ts",
    "lint": "run-s -c lint:*",
    "lint:oxlint": "oxlint",
    "lint:oxfmt": "oxfmt --check",
    "lint-fix": "run-s -c lint-fix:*",
    "lint-fix:oxfmt": "oxfmt --write",
    "lint-fix:oxlint": "npm run lint:oxlint -- --fix",
    "test": "vitest"
  },
  "dependencies": {
    "asearch": "^1.0.1",
    "preact": "^10.28.4"
  },
  "devDependencies": {
    "@mizdra/oxlint-config": "^0.1.0",
    "@preact/preset-vite": "^2.10.3",
    "@rollup/plugin-alias": "^3.1.2",
    "@rollup/plugin-commonjs": "^18.0.0",
    "@rollup/plugin-node-resolve": "^11.2.1",
    "@rollup/plugin-typescript": "^8.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^17.0.11",
    "@types/react-dom": "^17.0.5",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.16.0",
    "playwright": "^1.58.2",
    "rollup": "^2.45.2",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-visualizer": "^5.4.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "prettier": "@mizdra/prettier-config-mizdra",
  "renovate": "github>mizdra/renovate-config-mizdra:default.json5"
}
